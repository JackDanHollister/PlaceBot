# PlaceBot API Keys Configuration
# ================================
# Copy this file to .env and add your API keys
# Usage: cp .env.example .env

# Anthropic (Claude models)
# Get your key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI (GPT models)
# Get your key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Google (Gemini models)
# Get your key from: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here

# OpenRouter (multi-vendor routing through one key)
# Get your key from: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Optional: Multiple Gemini API keys for batch processing
# If you need to process large datasets, you can add multiple Gemini keys
# GOOGLE_API_KEY_2=your_second_google_api_key_here
# GOOGLE_API_KEY_3=your_third_google_api_key_here
# GOOGLE_API_KEY_4=your_fourth_google_api_key_here

# PlaceBot will automatically distribute large Gemini jobs across available
# Google keys.
